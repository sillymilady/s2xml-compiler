<?xml version="1.0" encoding="utf-8"?>
<!--
  action_share.bhav.xml
  Action: "Share Secret"
  Demonstrates <call> sugar element — calls the Pass Note BHAV as a subroutine,
  then adds extra relationship on top.
-->
<bhav
  name         = "Secret Rendezvous - Share Secret"
  group        = "0x7FD46CD0"
  instance     = "0x1004"
  tree_type    = "0"
  argc         = "0"
  locals       = "0"
  flags        = "0x01"
  tree_version = "0">

  <!-- Node 0: Call the Pass Note BHAV as a sub-routine -->
  <call
    bhav    = "0x1003"
    true    = "1"
    false   = "false"
    comment = "Call Pass Note BHAV (0x1003) as subroutine"/>

  <!-- Node 1: Extra +5 daily relationship on top -->
  <rel_change
    delta     = "5"
    type      = "0"
    direction = "2"
    true      = "2"
    false     = "false"
    comment   = "Extra daily rel +$REL_GAIN_SHARE (5)"/>

  <!-- Node 2: Return True -->
  <instruction
    opcode = "0x0001"
    true   = "true"
    false  = "false"
    comment= "Return True"/>

</bhav>
